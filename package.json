    "billing:config": "node scripts/apply-billing-configuration.mjs",
    "billing:import-provider-invoice": "node scripts/import-provider-invoice.mjs",
    "phase2:preflight": "node scripts/phase-two-preflight.mjs",
    "db:advisors": "supabase db advisors --local --fail-on warn",
