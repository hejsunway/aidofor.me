    "phase2:evaluate-provider": "node scripts/evaluate-provider-quality.mjs",
    "phase2:verify-cron-staging": "node scripts/verify-phase-two-cron-staging.mjs",
    "phase2:verify-scheduled-cron": "node scripts/verify-phase-two-scheduled-cron.mjs",
    "phase2:verify-stripe-staging": "node scripts/verify-phase-two-stripe-staging.mjs",
    "phase2:verify-topup-lifecycle": "node scripts/verify-phase-two-topup-lifecycle.mjs",
    "phase2:verify-subscription-lifecycle": "node scripts/verify-phase-two-subscription-lifecycle.mjs",
    "phase2:exercise-failed-renewal": "node scripts/exercise-phase-two-failed-renewal.mjs",
